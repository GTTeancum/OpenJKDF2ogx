	<Platforms>
		<Platform
			Name="Win32"
		/>
	</Platforms>
	<ToolFiles>
	</ToolFiles>
	<Configurations>
		<Configuration
			Name="Debug|Win32"
			OutputDirectory="$(SolutionDir)build\xbox\debug"
			IntermediateDirectory="$(SolutionDir)build\xbox\debug\obj"
			ConfigurationType="1"
			CharacterSet="2"
			>
			<Tool
				Name="VCPreBuildEventTool"
			/>
			<Tool
				Name="VCCustomBuildTool"
			/>
			<Tool
				Name="VCXMLDataGeneratorTool"
			/>
			<Tool
				Name="VCWebServiceProxyGeneratorTool"
			/>
			<Tool
				Name="VCMIDLTool"
			/>
			<Tool
				Name="VCCLCompilerTool"
				AdditionalOptions="/MT"
				Optimization="0"
				AdditionalIncludeDirectories="C:\XDK\xbox\include;$(SolutionDir)src;$(SolutionDir)src\Platform\Xbox;$(SolutionDir)3rdparty"
				PreprocessorDefinitions="TARGET_XBOX=1;SDL2_RENDER=1;STDSOUND_NULL=1;PLATFORM_NOSOCKETS=1;QOL_IMPROVEMENTS=1;TARGET_NO_MULTIPLAYER_MENUS=1;LINUX_TMP=1;_CRT_SECURE_NO_WARNINGS;_CRT_NONSTDC_NO_WARNINGS;WIN32;_DEBUG"
				MinimalRebuild="true"
				BasicRuntimeChecks="0"
				RuntimeLibrary="0"
				UsePrecompiledHeader="0"
				WarningLevel="2"
				DebugInformationFormat="4"
				CompileAs="1"
				DisableSpecificWarnings="4996;4244;4267;4305;4013;4133;4114;4028"
				ForcedIncludeFiles="platform_xbox.h"
			/>
			<Tool
				Name="VCManagedResourceCompilerTool"
			/>
			<Tool
				Name="VCResourceCompilerTool"
			/>
			<Tool
				Name="VCPreLinkEventTool"
			/>
			<Tool
				Name="VCLinkerTool"
				AdditionalDependencies="d3d8-xbox.lib dsound.lib xboxkrnl.lib xgraphics.lib xonline.lib libcd.lib xapilib.lib"
				OutputFile="$(OutDir)\openjkdf2_xbox.exe"
				AdditionalLibraryDirectories="C:\XDK\xbox\lib"
				IgnoreAllDefaultLibraries="false"
				IgnoreDefaultLibraryNames="libcmt.lib;libcmtd.lib;msvcrt.lib;msvcrtd.lib"
				GenerateDebugInformation="true"
				SubSystem="2"
				EntryPointSymbol="main"
			/>
			<Tool
				Name="VCALinkTool"
			/>
			<Tool
				Name="VCManifestTool"
			/>
			<Tool
				Name="VCXDCMakeTool"
			/>
			<Tool
				Name="VCBscMakeTool"
			/>
			<Tool
				Name="VCFxCopTool"
			/>
			<Tool
				Name="VCAppVerifierTool"
			/>
			<Tool
				Name="VCWebDeploymentTool"
			/>
			<Tool
				Name="VCPostBuildEventTool"
			/>
		</Configuration>
		<Configuration
			Name="Release|Win32"
			OutputDirectory="$(SolutionDir)build\xbox\release"
			IntermediateDirectory="$(SolutionDir)build\xbox\release\obj"
			ConfigurationType="0"
			>
			<Tool
				Name="VCNMakeTool"
				BuildCommandLine="$(SolutionDir)build_xbox.bat"
				ReBuildCommandLine="$(SolutionDir)build_xbox.bat clean &amp;&amp; $(SolutionDir)build_xbox.bat"
				CleanCommandLine="$(SolutionDir)build_xbox.bat clean"
				Output="$(OutDir)\openjkdf2_xbox.exe"
				PreprocessorDefinitions="TARGET_XBOX=1;SDL2_RENDER=1;STDSOUND_NULL=1;PLATFORM_NOSOCKETS=1;QOL_IMPROVEMENTS=1;TARGET_NO_MULTIPLAYER_MENUS=1;LINUX_TMP=1;WIN32;NDEBUG"
				IncludeSearchPath="C:\XDK\xbox\include;$(SolutionDir)src;$(SolutionDir)src\Platform\Xbox;$(SolutionDir)3rdparty"
				ForcedIncludes="platform_xbox.h"
			/>
		</Configuration>
	</Configurations>
